NODE_ENV=development
PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spotflow_integrations?retryWrites=true&w=majority

# Spotflow API (provided after sandbox onboarding)
SPOTFLOW_BASE_URL=
SPOTFLOW_API_KEY=
SPOTFLOW_WEBHOOK_SECRET=

# Reconciliation worker
PENDING_TIMEOUT_MINUTES=60
